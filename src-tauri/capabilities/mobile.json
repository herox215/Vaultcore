{
  "$schema": "../gen/schemas/android-schema.json",
  "identifier": "mobile-capability",
  "description": "VaultCore Android capabilities",
  "platforms": ["android"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}
